# ============================================================
# Orgconc - Conciliacao Bancaria - Configuracao de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no Git!
# ============================================================

# === SUPABASE (Banco de dados - Sao Paulo) ===
# Obtenha as keys em:
# https://supabase.com/dashboard/project/cmnbmckwvkfexfkegxsf/settings/api-keys/legacy
SUPABASE_URL=https://cmnbmckwvkfexfkegxsf.supabase.co
SUPABASE_ANON_KEY=PREENCHER_COM_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=PREENCHER_COM_SERVICE_ROLE_KEY
# Obtenha em: supabase.com -> Settings -> Database -> Connection string -> Transaction pooler (porta 6543)
DATABASE_URL=postgresql://postgres.cmnbmckwvkfexfkegxsf:PREENCHER_COM_DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# === AUTENTICACAO JWT ===
# Gere com: openssl rand -hex 32
JWT_SECRET=orgconc-jwt-secret-interno-2026-mudar-em-producao
ORGCONC_JWT_SECRET=orgconc-jwt-secret-interno-2026-mudar-em-producao
ORGCONC_JWT_TTL_MIN=120
ORGCONC_AUTH_TOKEN=orgconc-token-interno-2026

# === ADMIN (opcional) ===
ORGCONC_ADMIN_EMAIL=
ORGCONC_ADMIN_SENHA_HASH=

# === AMBIENTE ===
# development | staging | production
ORGCONC_ENV=development

# === CORS ===
ORGCONC_CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://localhost:3000,https://orgateccloud-bot.github.io

# === UPLOAD / DADOS ===
ORGCONC_MAX_UPLOAD_MB=50
ORGCONC_MAX_UPLOAD_TOTAL_MB=500
ORGCONC_DATA_DIR=./data

# === LOGGING ===
# true=JSON estruturado (producao) | false=texto legivel (dev)
ORGCONC_LOG_JSON=false
ORGCONC_LOG_LEVEL=INFO

# === ANTHROPIC (opcional - para analise com IA) ===
ANTHROPIC_API_KEY=

# === MONITORAMENTO DE CUSTO LLM (Trilha 3) ===
# Threshold diario em USD; quando o gasto acumulado UTC excede, dispara
# log WARNING "llm_custo_threshold_atingido" (1x por dia). 0 ou vazio = sem alerta.
ORGCONC_LLM_COST_ALERT_USD=

# Override de precos (USD por 1M tokens) — defaults: opus 15/75, sonnet 3/15, haiku 1/5
# ORGCONC_LLM_PRICE_OPUS_IN=15.0
# ORGCONC_LLM_PRICE_OPUS_OUT=75.0
# ORGCONC_LLM_PRICE_SONNET_IN=3.0
# ORGCONC_LLM_PRICE_SONNET_OUT=15.0
# ORGCONC_LLM_PRICE_HAIKU_IN=1.0
# ORGCONC_LLM_PRICE_HAIKU_OUT=5.0

# === OBSERVABILIDADE - SENTRY (Trilha 1) ===
# DSN do Sentry. Se vazio, Sentry nao eh inicializado (no-op).
SENTRY_DSN=
# Sample rate de tracing (0.0 a 1.0). Default 0.1 em prod, 1.0 em dev.
SENTRY_TRACES_SAMPLE_RATE=
# Ambiente (envia para Sentry). Se vazio, usa ORGCONC_ENV.
SENTRY_ENVIRONMENT=

# Copie para .env e preencha com sua chave real (.env esta no .gitignore)
ANTHROPIC_API_KEY=sk-ant-...

# Token opcional para proteger a API (se vazio, API fica aberta)
ORGCONC_AUTH_TOKEN=

# CORS: lista separada por virgula. Use * para liberar tudo (apenas em dev)
ORGCONC_CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Limite de upload em MB (default 10)
ORGCONC_MAX_UPLOAD_MB=10

# Diretorio onde os datasets sao persistidos (default ./data)
ORGCONC_DATA_DIR=./data

# ── Supabase / PostgreSQL ──────────────────────────────────────────────────
# Cole a connection string do Supabase (Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Copie para .env e preencha com seus valores reais (.env esta no .gitignore)

# ── Anthropic Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI

# ── Autenticacao ──────────────────────────────────────────────────────────
# JWT secret OBRIGATORIO em producao (>= 32 chars). Gere com:
#   openssl rand -hex 32
ORGCONC_JWT_SECRET=GERAR_COM_openssl_rand_-hex_32
# Access token: curto (default 15min). Refresh token estende a sessao.
ORGCONC_JWT_TTL_MIN=15
# Refresh token: longo (default 30 dias). Rotacionado a cada uso.
ORGCONC_REFRESH_TTL_DAYS=30

# Email + bcrypt-hash da senha do admin (gera o hash via POST /auth/hash em dev)
ORGCONC_ADMIN_EMAIL=
ORGCONC_ADMIN_SENHA_HASH=

# ── Ambiente ──────────────────────────────────────────────────────────────
# development | staging | production
# Em production: JWT_SECRET obrigatorio, modo anonimo bloqueado
ORGCONC_ENV=development

# ── CORS / Limites ────────────────────────────────────────────────────────
# CORS: lista separada por virgula. Use * para liberar tudo (apenas em dev)
ORGCONC_CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Limite de upload em MB (default 10) e diretorio de datasets
ORGCONC_MAX_UPLOAD_MB=10
ORGCONC_MAX_UPLOAD_TOTAL_MB=50
ORGCONC_DATA_DIR=./data

# ── Logging ───────────────────────────────────────────────────────────────
# true=JSON estruturado (producao) | false=texto legivel (dev)
ORGCONC_LOG_JSON=true
ORGCONC_LOG_LEVEL=INFO

# ── Redis (rate-limit distribuido + futura fila Arq) ──────────────────────
# Em multi-worker prod, sem REDIS_URL cada worker tem seu proprio contador
# (cliente pode burlar o limite). Em dev local pode deixar vazio.
# Local: redis://127.0.0.1:6379/0
# Upstash: rediss://default:<token>@<endpoint>.upstash.io:6379
REDIS_URL=

# ── Storage de datasets (item 15) ─────────────────────────────────────────
# local (default, FS) ou s3 (Supabase Storage, AWS S3, MinIO, ...)
ORGCONC_STORAGE_BACKEND=local

# So usado se backend=s3
S3_BUCKET=
S3_PREFIX=orgconc
S3_REGION=us-east-1
# Supabase: https://<projeto>.supabase.co/storage/v1/s3
# MinIO local: http://minio:9000
S3_ENDPOINT_URL=
# Credenciais boto3 padrao
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Sentry (item 19) ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
# Frontend: VITE_SENTRY_DSN (passar no build do React)
VITE_SENTRY_DSN=

# ── OCR para PDFs sem texto (scan / Print to PDF) ─────────────────────────
# Tesseract precisa estar instalado. Windows: https://github.com/UB-Mannheim/tesseract/wiki
ORGCONC_OCR_ENABLED=true
ORGCONC_OCR_MAX_PAGES=50
ORGCONC_OCR_LANG=por+eng
ORGCONC_OCR_DPI=200
# Override do binario se nao estiver no PATH (Windows tipico):
ORGCONC_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Claude Vision API para PDFs (alternativa premium ao OCR) ──────────────
# ?vision=true em /v1/conciliar/ofx manda paginas como imagem para o LLM.
# Custo alto — limite paginas para evitar surpresa na fatura.
ORGCONC_VISION_MAX_PAGES=20
ORGCONC_VISION_MODEL=claude-sonnet-4-6
ORGCONC_VISION_DPI=150

# ── SERPRO (consulta CPF/CNPJ) ─────────────────────────────────────────────
# Caminho da pasta com serpro_client.py (fora do repo, contém credenciais sensíveis)
ORGCONC_SERPRO_CLIENT_PATH=D:\integracoes\serpro

# Modo produção (OAuth2) — deixe vazio para usar o modo demo abaixo
ORGCONC_SERPRO_CONSUMER_KEY=
ORGCONC_SERPRO_CONSUMER_SECRET=

# Modo demonstração (token fixo fornecido pela doc do SERPRO) — mutuamente
# exclusivo com KEY/SECRET acima. Se ambos vazios, /serpro/* responde 503.
ORGCONC_SERPRO_DEMO_TOKEN=

# Pepper persistente para o hash de correlação em auditoria. OBRIGATÓRIO em
# produção (sem ele, logs ficam vulneráveis a rainbow-table de CPFs).
# Gere com: openssl rand -hex 32
ORGCONC_SERPRO_AUDIT_SALT=

# Override de paths (use os EXATOS do Swagger do seu contrato; default abaixo)
# ORGCONC_SERPRO_BASE_URL=https://gateway.apiserpro.serpro.gov.br
# ORGCONC_SERPRO_CPF_PATH=consulta-cpf-df/v1/cpf
# ORGCONC_SERPRO_CNPJ_PATH=consulta-cnpj-df/v2/empresa

# mTLS (e-CNPJ) — preencha se o seu contrato exigir certificado de cliente
# ORGCONC_SERPRO_CERT_FILE=
# ORGCONC_SERPRO_KEY_FILE=

# Timeout em segundos para chamadas HTTP ao gateway
ORGCONC_SERPRO_TIMEOUT_S=15

# ── Supabase / PostgreSQL ──────────────────────────────────────────────────
# Cole a connection string do Supabase (Settings -> Database -> Connection string)
# Use o pooler (porta 6543) com asyncpg + statement_cache_size=0
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<SENHA_AQUI>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
